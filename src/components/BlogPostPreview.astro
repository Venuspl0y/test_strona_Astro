---
import type { BlogPost } from "../types/blog";
export interface Props {
  post: BlogPost;
}

import { getSlugFromPath } from "../utils/get-slug-from-path";
import { parseISO, format } from "date-fns";

const { post } = Astro.props;
const url = "/blog/post/" + getSlugFromPath(post.file);

const date = parseISO(post.frontmatter.date);
const formattedDate = format(date, "dd/MM/yyyy");
---

<a
  href={url}
  class="group relative flex items-baseline justify-between gap-4 py-3"
>
  <span
    class="text-subtle group-hover:text-text transition-colors duration-200"
  >
    {post.frontmatter.title}
  </span>
  <span class="text-muted shrink-0 text-sm">{formattedDate}</span>
  <span
    class="bg-accent/40 absolute bottom-2 left-0 h-px w-0 transition-all duration-300 ease-out group-hover:w-full"
  >
  </span>
</a>
