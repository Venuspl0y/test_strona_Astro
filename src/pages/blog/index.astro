---
import "../../style/global.css";
import type { BlogPost } from "../../types/blog";
import BlogPostPreview from "../../components/BlogPostPreview.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const siteTitle = "blog";
const description = "Takie tam wypociny";

const allPosts = Object.values(
  import.meta.glob<BlogPost>("../../content/posts/*.md", { eager: true }),
);
const sortedPosts = allPosts
  .filter((post) => post.frontmatter.hidden !== true)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).valueOf() -
      new Date(a.frontmatter.date).valueOf(),
  );
---

<BaseLayout title={siteTitle} description={description}>
  <div class="mx-auto w-full max-w-4xl px-6 py-16">
    <header
      class="animate-fade-in-up mb-16 opacity-0"
      style="animation-delay: 0s;"
    >
      <h1 class="text-text text-2xl tracking-tight">blog</h1>
      <p class="text-muted mt-2 text-sm">
        Takie tam wypociny na ciekawe tematy..
      </p>
    </header>

    <div class="flex flex-col gap-1">
      {
        sortedPosts.map((post, i) => (
          <div
            class="animate-fade-in-up opacity-0"
            style={`animation-delay: ${(i + 1) * 0.05}s;`}
          >
            <BlogPostPreview post={post} />
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>
