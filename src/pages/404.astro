---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteTitle = "404";
const description = "Page not found";
---

<BaseLayout title={siteTitle} description={description}>
  <div class="flex min-h-screen flex-col items-center justify-center px-6">
    <div class="text-center">
      <h1
        class="text-text animate-fade-in-up text-8xl font-light tracking-tighter opacity-0"
        style="animation-delay: 0s;"
      >
        404
      </h1>
      <p
        class="text-muted animate-fade-in-up mt-4 text-sm tracking-wider opacity-0"
        style="animation-delay: 0.1s;"
      >
        Nic tu nie ma
      </p>
      <a
        href="/"
        class="text-subtle animate-fade-in-up hover:text-text mt-8 inline-block opacity-0 transition-colors duration-200"
        style="animation-delay: 0.2s;"
      >
        Wracam
      </a>
    </div>
  </div>
</BaseLayout>
